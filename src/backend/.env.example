# Environment Configuration Template for Ticket Management System Backend
# Copy this file to .env and update the values according to your environment

# Application Environment
# Options: development, production, test
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=localhost
API_VERSION=1.0.0

# Frontend URL for CORS configuration
# Update this to match your frontend application URL
FRONTEND_URL=http://localhost:5173

# Database Configuration
# MongoDB Atlas connection strings for different environments
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?options
MONGODB_DEV_URI=mongodb+srv://admin:StrongPassword123@cluster0.zfwkgle.mongodb.net/ticket_management_dev?retryWrites=true&w=majority&appName=Cluster0
MONGODB_TEST_URI=mongodb+srv://admin:StrongPassword123@cluster0.zfwkgle.mongodb.net/ticket_management_test?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=mongodb+srv://admin:StrongPassword123@cluster0.zfwkgle.mongodb.net/ticket_management_prod?retryWrites=true&w=majority&appName=Cluster0

# Database Connection Pool Settings
DB_MAX_POOL_SIZE=10
DB_SERVER_SELECTION_TIMEOUT=5000
DB_SOCKET_TIMEOUT=45000

# Optional: Database Authentication (if MongoDB requires auth)
# DB_AUTH_SOURCE=admin

# JWT Token Configuration
# IMPORTANT: Change JWT_SECRET in production to a strong, unique secret
JWT_SECRET=your-super-secure-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Password Hashing Configuration
# Higher values = more secure but slower (10-12 recommended for production)
BCRYPT_SALT_ROUNDS=12

# Rate Limiting Configuration
# Time window in milliseconds (15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000
# Maximum number of requests per window per IP
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
# Options: error, warn, info, verbose, debug
LOG_LEVEL=info
# Options: combined, common, dev, short, tiny
LOG_FORMAT=combined

# Security Configuration
HELMET_CSP_ENABLED=true
CORS_ENABLED=true